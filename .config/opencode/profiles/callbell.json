{
  "opencode": {
    "mcp": {
      "outline": {
        "enabled": true,
        "type": "local",
        "command": [
          "npx",
          "-y",
          "-p",
          "outline-mcp-server@latest",
          "outline-mcp-server-stdio"
        ]
      },
      "linear": {
        "enabled": true,
        "type": "remote",
        "url": "https://mcp.linear.app/mcp"
      },
      "sentry": {
        "enabled": true,
        "type": "remote",
        "url": "https://mcp.sentry.dev/mcp"
      }
    }
  },
  "oh_my_openagent": {
    "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
    "git_master": {
      "commit_footer": true,
      "include_co_authored_by": true,
      "git_env_prefix": "GIT_MASTER=1"
    },
    "agents": {
      "sisyphus": {
        "model": "anthropic/claude-opus-4-7",
        "variant": "max"
      },
      "oracle": {
        "model": "anthropic/claude-opus-4-7",
        "variant": "max"
      },
      "librarian": { "model": "anthropic/claude-haiku-4-5" },
      "explore": { "model": "anthropic/claude-haiku-4-5" },
      "multimodal-looker": { "model": "anthropic/claude-sonnet-4-6" },
      "prometheus": {
        "model": "anthropic/claude-opus-4-7",
        "variant": "max"
      },
      "metis": {
        "model": "anthropic/claude-opus-4-7",
        "variant": "max"
      },
      "momus": {
        "model": "anthropic/claude-opus-4-7",
        "variant": "max"
      },
      "atlas": { "model": "anthropic/claude-sonnet-4-6" },
      "sisyphus-junior": { "model": "anthropic/claude-sonnet-4-6" }
    },
    "categories": {
      "visual-engineering": {
        "model": "anthropic/claude-opus-4-7",
        "variant": "max"
      },
      "ultrabrain": {
        "model": "anthropic/claude-opus-4-7",
        "variant": "max"
      },
      "deep": {
        "model": "anthropic/claude-opus-4-7",
        "variant": "max"
      },
      "quick": { "model": "anthropic/claude-haiku-4-5" },
      "unspecified-low": { "model": "anthropic/claude-sonnet-4-6" },
      "unspecified-high": {
        "model": "anthropic/claude-opus-4-7",
        "variant": "max"
      },
      "writing": { "model": "anthropic/claude-sonnet-4-6" }
    }
  }
}
