{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@latest",
    "opencode-agent-memory@latest",
    "opencode-claude-auth@latest",
    "@ex-machina/opencode-anthropic-auth@1.7.5"
  ],
  "agent": {
    "plan": {
      "disable": true,
    },
    "build": {
      "disable": true,
    },
  },
  "lsp": {
    "ruby-lsp": {
      "command": ["/Users/muriloromeo/.asdf/shims/ruby-lsp"],
    },
  },
  "mcp": {
    "outline": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "-p",
        "outline-mcp-server@latest",
        "outline-mcp-server-stdio",
      ],
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
    },
  },
}
